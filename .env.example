# ──────────────────────────────────────────────────────────────────────────────
# Hallucination Detector Gym — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control — it is in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM / Inference API ──────────────────────────────────────────────────────
# The base URL for the OpenAI-compatible chat completions API.
API_BASE_URL=https://router.huggingface.co/v1

# Hugging Face token (used as the API key for the router).
# Get yours at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use for inference (must be served at API_BASE_URL).
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct

# ── Groq API (free, fast Llama inference for training) ───────────────────────
# Get a free key at https://console.groq.com
# Used by the training notebook (training_hallucination_detector.ipynb)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Environment Server ───────────────────────────────────────────────────────
# URL where the Hallucination Detector Gym server is running.
# For local development:
ENV_BASE_URL=http://localhost:8000

# Server port (used inside the container — HF Spaces expects 7860).
PORT=8000

# ── Agent Configuration ──────────────────────────────────────────────────────
# Max steps per episode before auto-submit.
MAX_STEPS=8

# LLM sampling temperature (lower = more deterministic).
TEMPERATURE=0.1

# Max tokens for LLM response.
MAX_TOKENS=800

# ── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Output structured JSON logs (true for production, false for dev).
LOG_JSON=false

# ── Deployment (OpenEnv / Hugging Face) ──────────────────────────────────────
# Enable the Gradio web UI at /web (set to true for HF Spaces deployments).
ENABLE_WEB_INTERFACE=true

# Your Hugging Face username (used by openenv push).
HF_USERNAME=williyam

# The repo-id for deployment (format: username/repo-name).
HF_REPO_ID=williyam/hallucination-detector-gym
